# Backend Environment Variables

# CORS Settings (Update with your frontend URL after deployment)
FRONTEND_URL=http://localhost:5173

# Hugging Face Inference token — required for /chat RAG, /roadmap,
# /interview/question, /interview/evaluate, and the LLM-augmented
# /summarize-cv. Get one at https://huggingface.co/settings/tokens (Read role).
HF_TOKEN=hf_...

# Optional — prefer local sentence-transformers over HF API for embeddings
# USE_LOCAL_EMBEDDINGS=true
